comment1.target=WatsonUI()
comment1.text=\r\n\ Construtor\ da\ classe\ WatsonUI.\r\n\ <p>\r\n\ Inicializa\ a\ imagem\ de\ Watson,\ redimensionando\ e\ espelhando\ horizontalmente.\r\n\ </p>\r\n
comment2.params=
